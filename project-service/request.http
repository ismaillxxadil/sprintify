@projectService = http://localhost:8082

# Use real user IDs from Identity Service.
@poUserId = cc2aa006-5542-4ad9-a0b9-754cae0e6052
@devUserId = d75d8764-216d-4433-a894-e5e9b44ce557

### 1) Create Project (PO)
# @name createProject
POST {{projectService}}/api/v1/projects/create
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "name": "Sprint Flow Project",
  "description": "Project for backlog and sprint flow testing",
  "state": "ACTIVE"
}

### 2) (Optional) Invite DEV to project
POST {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/invites
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "email": "user2@example.com",
  "role": "DEV"
}

### 3) Create Epic (PO)
# @name createEpic
POST {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "type": "EPIC",
  "title": "User Management",
  "description": "Top-level epic for user and access management",
  "priority": "HIGH",
  "difficulty": "MEDIUM",
  "estimatedPoints": 13
}

### 4) Create User Story under Epic (PO)
# @name createStory
POST {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "type": "USER_STORY",
  "title": "As a user, I can update my profile",
  "description": "Profile form with validation",
  "parentId": "{{createEpic.response.body.id}}",
  "priority": "MEDIUM",
  "difficulty": "MEDIUM",
  "estimatedPoints": 5
}

### 5) (Optional) Create Task under Story (DEV)
# Requires devUserId to be an active project member with DEV role.
# @name createTask
POST {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items
X-User-Id: {{devUserId}}
Content-Type: application/json

{
  "type": "TASK",
  "title": "Implement profile update endpoint",
  "description": "Add service and controller logic",
  "parentId": "{{createStory.response.body.id}}",
  "priority": "MEDIUM",
  "difficulty": "EASY",
  "estimatedPoints": 3
}

### 6) Update Story fields (general PATCH)
PATCH {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items/{{createStory.response.body.id}}
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "description": "Profile form with server-side validation and audit log",
  "priority": "HIGH",
  "estimatedPoints": 8,
  "estimatedHours": 12
}

### 7) Assign Story to PO (dedicated assign endpoint)
PATCH {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items/{{createStory.response.body.id}}/assign
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "assigneeId": "{{poUserId}}"
}

### 8) Create Sprint (PO)
# @name createSprint
POST {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/sprints
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "title": "Sprint 1",
  "startDate": "2026-04-21",
  "endDate": "2026-04-28",
  "sprintGoal": "Deliver first user profile capabilities"
}

### 9) Add Story to Sprint (planning only)
POST {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/sprints/{{createSprint.response.body.id}}/items
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "itemIds": [
    "{{createStory.response.body.id}}"
  ]
}

### 10) Start Sprint
POST {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/sprints/{{createSprint.response.body.id}}/start
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "comment": "Sprint kickoff"
}

### 11) Move story status to IN_PROGRESS
PATCH {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items/{{createStory.response.body.id}}/status
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "status": "IN_PROGRESS",
  "comment": "Work started"
}

### 12) Move story status to DONE
PATCH {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items/{{createStory.response.body.id}}/status
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "status": "DONE",
  "comment": "Completed"
}

### 13) Complete Sprint
POST {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/sprints/{{createSprint.response.body.id}}/complete
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "comment": "Sprint closed"
}

### 14) Validate sprint details and velocity
GET {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/sprints/{{createSprint.response.body.id}}

### 15) Validate backlog list (items not in sprint)
GET {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items

### 16) Validate sprint items list
GET {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items?sprintId={{createSprint.response.body.id}}

### 17) Unassign Story (tests nullable assigneeId)
PATCH {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items/{{createStory.response.body.id}}/assign
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "assigneeId": null
}

### 18) Move Story back to backlog (tests nullable sprintId)
PATCH {{projectService}}/api/v1/projects/{{createProject.response.body.id}}/backlog-items/{{createStory.response.body.id}}/sprint
X-User-Id: {{poUserId}}
Content-Type: application/json

{
  "sprintId": null
}

### 19) Cleanup: Delete project
DELETE {{projectService}}/api/v1/projects/{{createProject.response.body.id}}
X-User-Id: {{poUserId}}
